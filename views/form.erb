<h2>Add a Flight</h2>
<form method="post" action="/flight/details">
  <div class="form-group">
    <label for="airline">Airline</label>
    <select name="airline" id="airline">
      <% @airlines.each do |airline| %>
        <option value="<%= airline %>"><%= airline %></option>
      <% end %>
    </select>
  </div>
  <div class="form-group">
    <label for="flight_number">Flight Number</label>
    <select name="flight_number" id="flight_number">
      <% (1..99).to_a.each do |number| %>
        <option value=<%= number %>><%= number %></option>
      <% end %>
    </select>
  </div>
  <div class="form-group">
    <label for="origin">Origin</label>
    <select name="origin" id="origin">
      <% @airports.each do |code| %>
        <option value=<%= code %>><%= code %></option>
      <% end %>
    </select>
  </div>
  <div class="form-group">
    <label for="destination">Destination</label>
    <select name="destination" id="destination">
      <% @airports.each do |code| %>
        <option value=<%= code %>><%= code %></option>
      <% end %>
    </select>
  </div>
  <div class="form-group">
    <label for="time">Departure Time</label>
    <select name="hour" id="hour">
      <% (0..12).to_a.each do |number| %>
        <option value=<%= number %>><%= number %></option>
      <% end %>
    </select>
    <select name="minute" id="minute">
      <% (0..59).to_a.each do |number| %>
        <option value=<%= number %>><%= number %></option>
      <% end %>
    </select>
    <select name="meridiem" id="meridiem">
      <option value="PM">PM</option>
      <option value="AM">AM</option>
    </select>
  </div>
  <button type="submit">Submit</button>
</form>

<nav>
  <a href="/">View Flights</a>
</nav>
